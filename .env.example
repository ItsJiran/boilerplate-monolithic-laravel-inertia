# =============================================================================
# ------------------------ CONTAINER CONFIGURATION ----------------------------
# =============================================================================

# --- DOCKER CONFIGURATION ---
COMPOSE_PROJECT_NAME=your_app
DOCKER_IMAGE_TAG=latest

# --- GLOBAL APP CONFIGURATION --
APP_NAME="App Boilerplate"
APP_SLUG="app-boilerplate"
APP_ENV=local # -- local, development, staging, production
APP_DEBUG=true # -- true or false
APP_NETWORK="app_boilerplate_network"

VITE_APP_NAME={{APP_NAME}}
VITE_APP_ENV={{APP_ENV}}
VITE_APP_DEBUG={{APP_DEBUG}}

# --- PORTS (Global mapping) ---
LOAD_BALANCER_PORT=5000

SERVER_SERVICE=server
SERVER_PORT=8000

CLIENT_SERVICE=client-web
CLIENT_PORT=3000

# --- CLIENT USE THIS URL
APP_URL=app.test 
REVERB_URL=rev.app.test

# S3
S3_URL=s3.app.test
S3_CONSOLE_URL="minio.app.test"
# ASSET_URL=cdn.app.test

# --- SSL CONFIG (Development) ---
# For development using mkcert or Step CA
SSL_CERT_PATH=/etc/nginx/ssl/app-test.pem
SSL_KEY_PATH=/etc/nginx/ssl/app-test-key.pem
NODE_EXTRA_CA_CERTS=/home/usern/.local/share/mkcert/rootCA.pem

# --- STEP CA (Certificate Authority - DEVELOPMENT ONLY) ---
# Note: Production uses Let's Encrypt, not Step CA
STEP_CA_PORT=9696
STEP_CA_NAME="App CA"
STEP_CA_DNS="step-ca,localhost"
STEP_CA_PROVISIONER="admin"
STEP_CA_PASSWORD="changeme"
STEP_CA_ADMIN="admin@app.test"
STEP_CA_ADDRESS=":9696"
STEP_CA_URL=https://localhost:9696

# --- PRODUCTION SSL (Let's Encrypt) ---
# Uncomment for production deployment
# USE_LETSENCRYPT=true
# CERTBOT_EMAIL=admin@app.test
# DOMAIN=app.test
# WILDCARD_DOMAIN=*.app.test
