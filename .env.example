# =============================================================================
# ------------------------ CONTAINER CONFIGURATION ----------------------------
# =============================================================================

# --- DOCKER CONFIGURATION ---
COMPOSE_PROJECT_NAME=myapp_boilerplate
DOCKER_IMAGE_TAG=latest

# --- GLOBAL APP CONFIGURATION --
APP_NAME="App Boilerplate"
APP_SLUG="app-boilerplate"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://myapp.test
APP_NETWORK="app_boilerplate_network"

VITE_APP_NAME={{APP_NAME}}
VITE_APP_ENV={{APP_ENV}}
VITE_APP_DEBUG={{APP_DEBUG}}

# --- PORTS (Global mapping) ---
LOAD_BALANCER_PORT=5000

APP_SERVICE=server
APP_PORT=8000

# --- CLIENT USE THIS URL
APP_URL=myapp.test
API_URL=api.myapp.test
REVERB_URL=rev.myapp.test

# S3
S3_URL=s3.myapp.test
S3_CONSOLE_URL="minio.myapp.test"
# ASSET_URL=cdn.myapp.test

# --- SSL CONFIG (Development) ---
# For development using mkcert or Step CA
SSL_CERT_PATH=/etc/nginx/ssl/app-boilerplate.pem
SSL_KEY_PATH=/etc/nginx/ssl/app-boilerplate-key.pem
NODE_EXTRA_CA_CERTS=/home/itsjiran/Workspace/programming/260227_boilerplate_monolith_app_architecture/step-ca-public-root.pem

# --- STEP CA (Certificate Authority - DEVELOPMENT ONLY) ---
# Note: Production uses Let's Encrypt, not Step CA
STEP_CA_PORT=9898
STEP_CA_NAME="App Boilerplate CA"
STEP_CA_DNS="step-ca,localhost"
STEP_CA_PROVISIONER="admin"
STEP_CA_PASSWORD="changeme"
STEP_CA_ADMIN="admin@myapp.test"
STEP_CA_ADDRESS=":9898"
STEP_CA_URL=https://localhost:9898

# --- PRODUCTION SSL (Let's Encrypt) ---
# Uncomment for production deployment
# USE_LETSENCRYPT=true
# CERTBOT_EMAIL=admin@myapp.com
# DOMAIN=myapp.com
# WILDCARD_DOMAIN=*.myapp.com

# --- REVERB PUBLIC CONFIG ---
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=123456                      
REVERB_APP_SECRET=chan231    
REVERB_APP_KEY=pyrghf57am4rz3nxssow
REVERB_HOST="reverb"
REVERB_PORT=18080
REVERB_SCHEME=https
REVERB_URL=reverb.myapp.test

PUSHER_APP_KEY=12345678
PUSHER_APP_CLUSTER=mt1  

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

VITE_REVERB_URL="${REVERB_URL}"
VITE_REVERB_APP_ID="${REVERB_APP_ID}"
VITE_REVERB_APP_SECRET="${REVERB_APP_SECRET}"   
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"