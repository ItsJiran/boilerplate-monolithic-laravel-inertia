# ==============================================================================
# CONTAINER & APP CONFIGURATION
# ==============================================================================

# --- DOCKER CONFIGURATION -----------------------------------------------------
COMPOSE_PROJECT_NAME=boilerplate
DOCKER_IMAGE_NAME=ghcr.io/username/repo
DOCKER_IMAGE_TAG=latest

# --- GLOBAL APP CONFIGURATION -------------------------------------------------
APP_NAME="Myapp"
APP_SLUG="myapp"
APP_ENV=local
APP_KEY=base64:sd0kx61QbQwyjAKQPetP5eUstHQj8BNYwWtl2XJlwSo=
APP_VERSION=v0.0
APP_DEBUG=true
APP_NETWORK="myapp"

VITE_APP_NAME="${APP_NAME}"
VITE_APP_ENV="${APP_ENV}"
VITE_APP_DEBUG="${APP_DEBUG}"

# --- DOMAINS & URLS (CLIENT USE THIS URL) -------------------------------------
APP_SCHEME=https
APP_DOMAIN=myapp.test
APP_URL="${APP_SCHEME}://${APP_DOMAIN}"

API_DOMAIN=api.myapp.test
API_URL="${APP_SCHEME}://${API_DOMAIN}"

REVERB_DOMAIN=reverb.myapp.test
REVERB_URL="${APP_SCHEME}://${REVERB_DOMAIN}"

PMA_DOMAIN=phpmyadmin.myapp.test
PMA_ABSOLUTE_URI="${APP_SCHEME}://${PMA_DOMAIN}"

# --- SANCTUM SETUP ------------------------------------------------------------
SESSION_DOMAIN=.${APP_DOMAIN}
SESSION_SECURE_COOKIE=true

# --- PORTS (Global mapping) ---------------------------------------------------
LOAD_BALANCER_PORT=5252
LOAD_BALANCER_HMR_PORT=5353

HMR_URL=hmr.myapp.test
VITE_HMR_URL=${HMR_URL}

APP_SERVICE=app
APP_PORT=8000

# IMPORTANT FOR DEV
APP_EXTRA_HOST="host-gateway"
API_EXTRA_HOST="10.240.37.196"

# --- S3 STORAGE ---------------------------------------------------------------
S3_DOMAIN=s3.myapp.test
S3_URL="${APP_SCHEME}://${S3_DOMAIN}"
S3_CONSOLE_DOMAIN=minio.myapp.test
S3_CONSOLE_URL="${APP_SCHEME}://${S3_CONSOLE_DOMAIN}"

# Kalau pakai cdn
# ASSET_URL=cdn.myapp.com

# ==============================================================================
# SECURITY & SSL CONFIGURATION
# ==============================================================================

# --- SSL CONFIG (Development) -------------------------------------------------
# For development using mkcert or Step CA
SSL_CERT_PATH=/etc/nginx/ssl/myapp.pem
SSL_KEY_PATH=/etc/nginx/ssl/myapp.key

# --- STEP CA (Certificate Authority - DEVELOPMENT ONLY) -----------------------
# Note: Production uses Let's Encrypt, not Step CA
STEP_CA_PORT=9696
STEP_CA_NAME="App Boilerplate CA"
STEP_CA_DNS="step-ca,localhost"
STEP_CA_PROVISIONER="admin"
STEP_CA_PASSWORD="changeme"
STEP_CA_ADMIN="admin@myapp.test"
STEP_CA_ADDRESS=":9696"
STEP_CA_URL=https://localhost:9696

# --- PRODUCTION SSL (Let's Encrypt) -------------------------------------------
# Uncomment for production deployment
# USE_LETSENCRYPT=true
# CERTBOT_EMAIL=admin@myapp.com

# ==============================================================================
# BROADCASTING & WEBSOCKETS
# ==============================================================================

# --- REVERB PUBLIC CONFIG -----------------------------------------------------
REVERB_APP_ID=123456              
REVERB_APP_SECRET=esachan231   
REVERB_APP_KEY=pyrghf57am4rz3nxssow
REVERB_HOST="app-socket"
REVERB_PORT=18080
REVERB_SCHEME=http

PUSHER_APP_KEY=12345678
PUSHER_APP_CLUSTER=mt1  

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

VITE_REVERB_URL="${REVERB_URL}"
VITE_REVERB_APP_ID="${REVERB_APP_ID}"
VITE_REVERB_APP_SECRET="${REVERB_APP_SECRET}"   
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# --- 1. LARAVEL -> REVERB (Internal Docker Connection) ------------------------
REVERB_HOST="app-socket"
REVERB_PORT=18080
REVERB_SCHEME="https"

REVERB_SERVER_HOST="0.0.0.0"
REVERB_SERVER_PORT="${REVERB_PORT}"
REVERB_SERVER_PATH=""

# --- 2. BROWSER -> REVERB (Public/Vite Connection) ----------------------------
# Notice we DO NOT use ${REVERB_HOST} here!
VITE_REVERB_HOST="reverb.myapp.test"
VITE_REVERB_PORT=443 # Assuming you are using HTTPS/SSL for the public domain
VITE_REVERB_SCHEME="https"

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_APP_ID="${REVERB_APP_ID}"
VITE_REVERB_APP_SECRET="${REVERB_APP_SECRET}"

# (Optional: If your echo.js still uses Pusher keys, make sure they match Reverb!)
VITE_PUSHER_APP_KEY="${REVERB_APP_KEY}"
BROADCAST_CONNECTION=reverb