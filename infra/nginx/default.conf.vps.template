    listen 443 ssl http2;
    server_name {{S3_URL}} *.{{APP_DOMAIN}};

    ssl_certificate     {{S3_SSL_CERT}};
    ssl_certificate_key {{S3_SSL_KEY}};

    # MinIO Specifics
    client_max_body_size 0;
    proxy_buffering off;
    proxy_request_buffering off;

    access_log /var/log/nginx/app-boilerplate_s3_access.log;
    error_log  /var/log/nginx/app-boilerplate_s3_error.log warn;

