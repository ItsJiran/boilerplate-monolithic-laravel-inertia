    listen 443 ssl http2;
    server_name {{S3_URL}} *.{{APP_URL}};

    ssl_certificate     {{SSL_CERT_PATH}};
    ssl_certificate_key {{SSL_KEY_PATH}};

    # MinIO Specifics
    client_max_body_size 0;
    proxy_buffering off;
    proxy_request_buffering off;

    access_log /var/log/nginx/citrakuliner_s3_access.log;
    error_log  /var/log/nginx/citrakuliner_s3_error.log warn;

